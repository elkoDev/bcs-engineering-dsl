controller MainController {
    sensor MainTempSensor1 {
        type: TEMPERATURE
        ioType: DI
        dataType: REAL
    }

    sensor MainTempSensor2 {
        type: TEMPERATURE
        ioType: DI
        dataType: REAL
    }

    actuator MainHeatingValve1 {
        type: VALVE
        ioType: DO
        dataType: BOOL
    }

    actuator MainHeatingValve2 {
        type: VALVE
        ioType: DO
        dataType: BOOL
    }
}