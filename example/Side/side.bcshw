controller SideController {
    sensor SideTempSensor1 {
        type: TEMPERATURE
        ioType: DI
        dataType: REAL
    }

    sensor SideTempSensor2 {
        type: TEMPERATURE
        ioType: DI
        dataType: REAL
    }

    actuator SideHeatingValve1 {
        type: VALVE
        ioType: DO
        dataType: BOOL
    }

    actuator SideHeatingValve2 {
        type: VALVE
        ioType: DO
        dataType: BOOL
    }
}