controller RoomCtrl {
    sensor tempSensor {
        type: TEMPERATURE
        ioType: ANALOG
        dataType: REAL
    }

    sensor presenceSensor {
        type: OCCUPANCY
        ioType: DIGITAL
        dataType: BOOL
    }

    sensor windowContact {
        type: CONTACT
        ioType: DIGITAL
        dataType: BOOL
    }

    actuator heater {
        type: HEATER
        ioType: DIGITAL
        dataType: BOOL
    }

    actuator light {
        type: LIGHT
        ioType: DIGITAL
        dataType: BOOL
    }
}
