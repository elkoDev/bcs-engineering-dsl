// A minimal hardware definition to accompany library_call_test.bcsctrl
bus FieldBus type EtherCAT {
    masterDevice: "Device 1 (EtherCAT)"
    box Coupler {
        product: EK1100
        module IOModule_AI1 {
            product: EL3074
            position: 1
        }
        module IOModule_DI1 {
            product: EL1008
            position: 2
        }
        module IOModule_DO1 {
            product: EL2024
            position: 3
        }
        module IOModule_AO1 {
            product: EL4024
            position: 4
        }
        module IOModule_DALI {
            product: EL6821
            position: 5
        }
    }
}

controller LibraryCallTestController {
    portgroup DI {
        module: IOModule_DI1
        ioType: DIGITAL_INPUT
        channels: 8
    }

    portgroup DALI_OUTPUT {
        module: IOModule_DALI
        ioType: DIGITAL_OUTPUT
        channels: 8
    }
}