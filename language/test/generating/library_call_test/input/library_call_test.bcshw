// A minimal hardware definition to accompany library_call_test.bcsctrl
controller LibraryCallTestController for Beckhoff {
    portgroup DI {
        moduleType: EL1008
        ioType: DIGITAL_INPUT
        startAddress: %IX0.0
        channels: 8
    }

    portgroup DALI_OUTPUT {
        moduleType: KL6821
        ioType: DIGITAL_OUTPUT
        startAddress: %QW0
        channels: 8
    }
}