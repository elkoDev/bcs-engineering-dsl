// A test file for array code generation
control ValidTestController {
    functionblock ArrayTestFB {
        inputs {
            var iValues: INT[10];
            var iCount: INT;
        }
        outputs {
            var oSum: INT;
            var oAverage: REAL;
            var oMaxValue: INT;
            var oProcessedValues: INT[10];
        }
        locals {
            var i: INT;
            var sum: INT = 0;
            var maxVal: INT = -32768; // Minimum INT value
        }
        logic {
            // Reset calculations
            sum = 0;
            maxVal = -32768;
            
            // Process array elements
            for (var i: INT = 0 to 10 by i) {
                // Calculate sum
                sum = sum + iValues[i];
                
                // Find maximum value
                if (iValues[i] > maxVal) {
                    maxVal = iValues[i];
                }
                
                // Process and store values (multiply by 2)
                oProcessedValues[i] = iValues[i] * 2;
            }
            
            // Zero out remaining array elements
            for (var i: INT = iCount to 10 by i) {
                oProcessedValues[i] = 0;
            }
            
            // Set outputs
            oSum = sum;
            oMaxValue = maxVal;
            
            // Calculate average (avoid division by zero)
            if (iCount > 0) {
                oAverage = sum / iCount;
            } else {
                oAverage = 0.0;
            }
        }
    }

    unit TestArrays {
        var values: INT[10] = [10, 20, 30, 40, 50, -5, 15, 25, 35, 45];
        var count: INT = 8;
        var sum: INT;
        var average: REAL;
        var maxValue: INT;
        var processedValues: INT[10];
        
        use ArrayTestFB(
            iValues: values,
            iCount: count
        ) -> {
            oSum: sum,
            oAverage: average,
            oMaxValue: maxValue,
            oProcessedValues: processedValues
        };
    }
}