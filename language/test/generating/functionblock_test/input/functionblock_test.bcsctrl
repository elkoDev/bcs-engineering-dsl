// A test file for function block code generation
control FunctionBlockTestController {
    functionblock SimpleLogicFB {
        inputs {
            var iInput: BOOL;
            var iInput2: INT;
        }
        outputs {
            var oOutput: BOOL;
        }
        locals {
            var iInputNegated: BOOL;
        }
        logic {
            oOutput = iInput;
            after T#1s if (oOutput == true) then {
                oOutput = false;
            }
            on_rising(iInput) {
                oOutput = true;
            }
            on_falling(iInput) {
                oOutput = false;
            }
        }
    }

    unit TestFunctionBlock {
        var input: BOOL = true;
        var input2: INT = 5;
        var input3: BOOL = false;
        var input4: INT = 10;
        var output: BOOL;
        var output2: BOOL;
        use SimpleLogicFB(iInput: input, iInput2: input2) -> { oOutput: output };
        use SimpleLogicFB(iInput: input3, iInput2: input4) -> { oOutput: output2 };

        on_falling(input) {
            output = false;
        }
    }
}