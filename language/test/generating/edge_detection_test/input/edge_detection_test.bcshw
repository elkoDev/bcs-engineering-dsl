// Hardware configuration for edge detection test
controller ValidTestController for Beckhoff {
    portgroup DI {
        moduleType: EL1008
        ioType: DIGITAL_INPUT
        startAddress: %IX0.0
        channels: 8
    }
    
    portgroup DO {
        moduleType: EL2008
        ioType: DIGITAL_OUTPUT
        startAddress: %QX0.0
        channels: 8
    }
}