control InvalidDuplicateController {
    var globalVar: BOOL;
    enum DuplicateMode {
        COMFORT,
        ECO,
        OFF
    }
    enum DuplicateMode {
        COMFORT2,
        ECO2,
        OFF2
    }
    struct DuplicateStruct {
        x: REAL,
        y: REAL
    }
    struct DuplicateStruct {
        x: REAL,
        y: REAL
    }
    functionblock DuplicateFB {
        inputs {
            var iDuplicate: REAL;
            var iDuplicate: BOOL;
        }
        inputs {
            var iDuplicate2: REAL;
            var iDuplicate3: BOOL;
        }
        locals {
            var lDuplicate: BOOL;
            var lDuplicate: BOOL;
            var duplicateFBVar: BOOL;
            var duplicateFBVar: BOOL;
        }
        locals {
            var lDuplicate2: BOOL;
            var lDuplicate3: BOOL;
            var duplicateFBVar2: BOOL;
            var duplicateFBVar3: BOOL;
        }
        outputs {
            var oDuplicate: BOOL;
            var oDuplicate: BOOL;
        }
        outputs {
            var oDuplicate2: BOOL;
            var oDuplicate3: BOOL;
        }
    }
    functionblock DuplicateFB {
    }
    var duplicateVar: BOOL;
    var duplicateVar: BOOL;
    unit DuplicateUnit {
        var duplicateUnitVar: BOOL;
        var duplicateUnitVar: BOOL;
    }
    unit DuplicateUnit {        
    // Cannot declare a variable with the same name as in the global scope 
        var globalVar: INT;
        var duplicateNestedUnitVar: BOOL;
        while (true){
        // Nested variable declarations are no longer allowed by grammar
            // Variable access still works within nested blocks
            duplicateNestedUnitVar = true;
        }
        on_rising(windowContact.value){
        // Nested variable declarations are no longer allowed by grammar
            // Variable access still works within nested blocks
            duplicateNestedUnitVar = false;
        }
        on_rising(windowContact.value){
        // Nested variable declarations are no longer allowed by grammar
            // Variable access still works within nested blocks  
            duplicateNestedUnitVar = true;
        }
        for (var i: INT = 0 to 10){
        // Nested variable declarations are no longer allowed by grammar
            // Variable access still works within nested blocks
            duplicateNestedUnitVar = false;
        }
        switch (windowContact.value){
            case true:{
            // Nested variable declarations are no longer allowed by grammar
                // Variable access still works within nested blocks
                duplicateNestedUnitVar = true;
            }
            case false:{
            // Nested variable declarations are no longer allowed by grammar
                // Variable access still works within nested blocks
                duplicateNestedUnitVar = false;
            }
        }
    }
}
