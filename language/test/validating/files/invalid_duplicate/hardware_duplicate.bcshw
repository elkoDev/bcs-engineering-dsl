bus FieldBus type EtherCAT {
    masterDevice: "Device 1 (EtherCAT)"
    box Coupler {
        product: EK1100
        module IOModule_AI1 {
            product: KL3064
            position: 1
        }
        module IOModule_DI1 {
            product: EL1008
            position: 2
        }
        module IOModule_DO1 {
            product: KL2408
            position: 3
        }
        module IOModule_AO1 {
            product: KL3064
            position: 4
        }
        module IOModule_DALI {
            product: KL6811
            position: 5
        }
    }
}

controller InvalidDuplicateController for Beckhoff {
    portgroup DigitalInputs {
        module: IOModule_DI1
        ioType: DIGITAL_INPUT
        channels: 8
    }

    datapoint windowContact {
        portgroup: DigitalInputs
        channels: {
            channel value: BOOL at 0
        }
    }

    datapoint windowContact_duplicate {
        portgroup: DigitalInputs
        channels: {
            channel value: BOOL at 0
        }
    }

    datapoint windowContact_duplicate {
        portgroup: DigitalInputs
        channels: {
            channel value: BOOL at 1
        }
    }

    portgroup DigitalOutputs {
        module: IOModule_DO1
        ioType: DIGITAL_OUTPUT
        channels: 8
    }

    datapoint motor {
        portgroup: DigitalOutputs
        channels: {
            channel value: BOOL at 0
        }
    }

    datapoint motor {
        portgroup: DigitalOutputs
        channels: {
            channel value: BOOL at 1
        }
    }
}
