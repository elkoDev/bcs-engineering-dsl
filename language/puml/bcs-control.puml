@startuml
skinparam linetype ortho
hide empty members

' ===== CORE STRUCTURE =====
package "Core Structure" {
  class ControlModel
  class ControlBlock
  abstract class ControlItem
  class ControlUnit {
    name: string
    isOnce: boolean
    condition: Expr
    time: TodLiteral
  }
  class ImportDecl {
    name: string
  }
}

' ===== DECLARATIONS & TYPES =====
package "Declarations & Types" {
  abstract class Declaration
  abstract class TypeDecl extends Declaration {
    isExtern: boolean
  }
  class VarDecl extends Declaration {
    name: string
    init: Expr
  }
  note bottom of VarDecl: The AST also classifies VarDecl as a Statement
  class StructDecl extends TypeDecl {
    name: string
  }
    class StructFieldDecl {
        name: string
        init: Expr
    }
  class EnumDecl extends TypeDecl {
    name: string
  }
    class EnumMemberDecl {
        name: string
    }
  class FunctionBlockDecl extends TypeDecl {
    name: string
  }
    abstract class FunctionBlockMember
    class FunctionBlockInputs extends FunctionBlockMember
    class FunctionBlockOutputs extends FunctionBlockMember
    class FunctionBlockLocals extends FunctionBlockMember
    class FunctionBlockLogic extends FunctionBlockMember
  class TypeAlias extends TypeDecl {
      name: string
      primitive: PrimitiveType
  }
  class TypeRef
}

' ===== STATEMENTS & EXPRESSIONS =====
package "Statements & Expressions" {
  abstract class Statement
  class AssignmentStmt extends Statement
  class IfStmt extends Statement
    class ElseIfStmt
    class ElseStmt
  class WhileStmt extends Statement
  class ForStmt extends Statement
  class SwitchStmt extends Statement
    class CaseOption
    class DefaultOption
  class UseStmt extends Statement
  class AfterStmt extends Statement
  abstract class EdgeStmt extends Statement
  class OnRisingEdgeStmt extends EdgeStmt
  class OnFallingEdgeStmt extends EdgeStmt
  abstract class LoopControlStmt extends Statement
  class ContinueStmt extends LoopControlStmt
  class BreakStmt extends LoopControlStmt
  class ExpressionStmt extends Statement
  
  class InputMapping
  class UseOutput
  class SimpleUseResult
  class MappingUseResult

  abstract class Expr
  class Ref extends Expr
}

' Abstract element for what can be referenced by name
abstract class NamedElement
NamedElement <|-- VarDecl
NamedElement <|-- StructDecl
NamedElement <|-- EnumDecl
' NamedElement <|-- Datapoint (from Hardware DSL) is implied

' ===== RELATIONSHIPS =====

' --- Core Structure ---
ControlModel "1" *-- "0..*" ImportDecl
ControlModel "1" *-- "0..*" TypeDecl : externTypeDecls
ControlModel "1" *-- "1" ControlBlock
ControlBlock "1" *-- "0..*" ControlItem
ControlBlock "1" ..> "1" Controller : controller
ControlItem <|-- Declaration
ControlItem <|-- ControlUnit

' --- Declarations ---
Declaration <|-- VarDecl
Declaration <|-- TypeDecl
TypeDecl <|-- EnumDecl
TypeDecl <|-- StructDecl
TypeDecl <|-- FunctionBlockDecl
TypeDecl <|-- TypeAlias

' Declaration Compositions
StructDecl "1" *-- "0..*" StructFieldDecl : fields
EnumDecl "1" *-- "1..*" EnumMemberDecl : members
VarDecl "1" *-- "1" TypeRef
StructFieldDecl "1" *-- "1" TypeRef
TypeRef "1" ..> "0..1" TypeDecl : ref

' FunctionBlock Compositions
FunctionBlockDecl "1" *-- "0..*" FunctionBlockMember : members
FunctionBlockDecl "1" ..> "0..1" ImportDecl : libRef
FunctionBlockMember <|-- FunctionBlockInputs
FunctionBlockMember <|-- FunctionBlockOutputs
FunctionBlockMember <|-- FunctionBlockLocals
FunctionBlockMember <|-- FunctionBlockLogic
FunctionBlockInputs  "1" *-- "0..*" VarDecl : inputs
FunctionBlockOutputs "1" *-- "0..*" VarDecl : outputs
FunctionBlockLocals  "1" *-- "0..*" VarDecl : locals
FunctionBlockLogic   "1" *-- "0..*" Statement : stmts

' --- Statements ---
ControlUnit "1" *-- "0..*" Statement : stmts
Statement <|-- AssignmentStmt
Statement <|-- IfStmt
Statement <|-- WhileStmt
Statement <|-- ForStmt
Statement <|-- SwitchStmt
Statement <|-- UseStmt
Statement <|-- AfterStmt
Statement <|-- EdgeStmt
Statement <|-- LoopControlStmt
Statement <|-- ExpressionStmt
Statement <|-- VarDecl 
' This represents LocalVarDeclStmt

' Statement Compositions and References
IfStmt "1" *-- "0..*" ElseIfStmt
IfStmt "1" *-- "0..1" ElseStmt
WhileStmt "1" *-- "1" Expr : condition
ForStmt "1" *-- "1" VarDecl : loopVar
SwitchStmt "1" *-- "1..*" CaseOption
SwitchStmt "1" *-- "0..1" DefaultOption
UseStmt "1" ..> "1" FunctionBlockDecl : functionBlockRef
UseStmt "1" *-- "0..*" InputMapping : inputArgs
UseStmt "1" *-- "1" UseOutput
EdgeStmt "1" *-- "1" Ref : signal
Ref ..> NamedElement : ref

note bottom of Expr
  The Expr hierarchy (BinExpr, Primary, etc.)
  is simplified to this abstract class for clarity.
end note

@enduml