{
  "projectName": "BCSEngineeringDSL",
  "languages": [
    {
      "id": "bcs-hardware-lang",
      "grammar": "src/language/bcs-hardware.langium",
      "fileExtensions": ["bcshw"],
      "textMate": {
        "out": "syntaxes/bcs-hardware.tmLanguage.json"
      },
      "monarch": {
        "out": "syntaxes/bcs-hardware.monarch.ts"
      },
      "railroad": {
        "out": "railroad/svg/bcs-hardware",
        "mode": "svg"
      }
    },
    {
      "id": "bcs-control-lang",
      "grammar": "src/language/bcs-control.langium",
      "fileExtensions": ["bcsctrl"],
      "textMate": {
        "out": "syntaxes/bcs-control.tmLanguage.json"
      },
      "monarch": {
        "out": "syntaxes/bcs-control.monarch.ts"
      },
      "railroad": {
        "out": "railroad/svg/bcs-control",
        "mode": "svg"
      }
    }
  ],
  "out": "src/language/generated"
}
