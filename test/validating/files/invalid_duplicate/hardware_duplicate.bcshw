controller InvalidDuplicateController for Beckhoff {
    portgroup DigitalInputs {
        moduleType: EL1008
        ioType: DIGITAL_INPUT
        startAddress: %IX0.0
        channels: 8
    }

    datapoint windowContact {
        portgroup: DigitalInputs
        channels: {
            channel value: BOOL at 0
        }
    }

    datapoint windowContact_duplicate {
        portgroup: DigitalInputs
        channels: {
            channel value: BOOL at 0
        }
    }

    datapoint windowContact_duplicate {
        portgroup: DigitalInputs
        channels: {
            channel value: BOOL at 1
        }
    }

    portgroup DigitalOutputs {
        moduleType: KL2408
        ioType: DIGITAL_OUTPUT
        startAddress: %QX0.0
        channels: 8
    }

    datapoint motor {
        portgroup: DigitalOutputs
        channels: {
            channel value: BOOL at 0
        }
    }

    datapoint motor {
        portgroup: DigitalOutputs
        channels: {
            channel value: BOOL at 1
        }
    }
}
