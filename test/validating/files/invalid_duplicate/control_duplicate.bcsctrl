control InvalidDuplicateController {
    var globalVar: BOOL;

    enum DuplicateMode {
        COMFORT,
        ECO,
        OFF
    }
    enum DuplicateMode {
        COMFORT2,
        ECO2,
        OFF2
    }

    functionblock DuplicateFB {
        inputs {
            var iDuplicate: REAL;
            var iDuplicate: BOOL;
        }
        inputs {
            var iDuplicate2: REAL;
            var iDuplicate3: BOOL;
        }
        locals {
            var lDuplicate: BOOL;
            var lDuplicate: BOOL;
        }
        locals {
            var lDuplicate2: BOOL;
            var lDuplicate3: BOOL;
        }
        outputs {
            var oDuplicate: BOOL;
            var oDuplicate: BOOL;
        }
        outputs {
            var oDuplicate2: BOOL;
            var oDuplicate3: BOOL;
        }
        logic {
            var duplicateFBVar: BOOL;
            var duplicateFBVar: BOOL;
        }
        logic {
            var duplicateFBVar2: BOOL;
            var duplicateFBVar3: BOOL;
        }
    }
    functionblock DuplicateFB {
    }

    var duplicateVar: BOOL;
    var duplicateVar: BOOL;

    unit DuplicateUnit {
        var duplicateUnitVar: BOOL;
        var duplicateUnitVar: BOOL;
    }

    unit DuplicateUnit {        
        // Cannot declare a variable with the same name as in the global scope 
        var globalVar: INT;

        var duplicateNestedUnitVar: BOOL;
        while (true) {
            var localWhileVar: BOOL;
            // Cannot declare a variable with the same name as in the while scope
            var localWhileVar: BOOL;
            // Cannot declare a variable with the same name as in the global scope
            var globalVar: INT;
            // Cannot declare a variable with the same name as in the unit scope
            var duplicateNestedUnitVar: BOOL;
        }

        on_rising(windowContact.value) {
            var localOnRisingVar: BOOL;
            // Cannot declare a variable with the same name as in the on_rising scope
            var localOnRisingVar: BOOL;
            // Cannot declare a variable with the same name as in the global scope
            var globalVar: INT;
            // Cannot declare a variable with the same name as in the unit scope
            var duplicateNestedUnitVar: BOOL;
        }

        on_rising(windowContact.value) {
            var localOnRisingVar: BOOL;
            // Cannot declare a variable with the same name as in the on_rising scope
            var localOnRisingVar: BOOL;
            // Cannot declare a variable with the same name as in the global scope
            var globalVar: INT;
            // Cannot declare a variable with the same name as in the unit scope
            var duplicateNestedUnitVar: BOOL;
        }

        for (var i: INT = 0 to 10) {
            var localForVar: BOOL;
            // Cannot declare a variable with the same name as in the for scope
            var localForVar: BOOL;
            // Cannot declare a variable with the same name as in the global scope
            var globalVar: INT;
            // Cannot declare a variable with the same name as in the unit scope
            var duplicateNestedUnitVar: BOOL;
        }

        switch (windowContact.value) {
            case true: {
                var localSwitchVar: BOOL;
                // Cannot declare a variable with the same name as in the switch scope
                var localSwitchVar: BOOL;
                // Cannot declare a variable with the same name as in the global scope
                var globalVar: INT;
                // Cannot declare a variable with the same name as in the unit scope
                var duplicateNestedUnitVar: BOOL;
            }

            case false: {
                // Cannot declare a variable with the same name as in the global scope
                var globalVar: INT;
                // Cannot declare a variable with the same name as in the unit scope
                var duplicateNestedUnitVar: BOOL;
            }
        }
    }
}
