control ValidTestController {

    enum Mode { OFF, ECO, COMFORT }

    var windowOpen: BOOL;
    var temp: REAL = 0.0;
    var intTemp: INT = 4;
    var heater: BOOL;
    var lights: BOOL;
    var lightLevel: INT = 0;

    functionblock LightLogicFB {
        inputs {
            var iLightLevel: INT;
        }
        outputs {
            var oLight: BOOL;
            var oDimmedLight: INT;
        }
        logic {
            if (iLightLevel > 50) {
                oLight = true;
                oDimmedLight = iLightLevel - 50;
            } else {
                oLight = false;
                oDimmedLight = 0;
            }
        }
    }

        functionblock HeatingLogicFB {
        inputs {
            var iTemp: REAL;
            var iWindow: BOOL;
            var iMode: Mode;
        }
        outputs {
            var oHeating: BOOL;
        }
        logic {
            if (iWindow) {
                oHeating = false || (iTemp < 18.0);
            } else if (iMode == Mode.COMFORT && iTemp < 21.0) {
                oHeating = true;
            } else if (iMode == Mode.ECO && iTemp < 18.0) {
                oHeating = true;
            } else {
                oHeating = false;
            }
        }
    }

    unit TestUnit {
        heater = (temp > 5.5) || (temp < 4.5) || (temp > 6.0 && temp < 7.0) && false;
        temp = 5.0 + 5 - 4.0 / 4;
        windowOpen = windowContact || (temp > 5.0 && temp < 6.0) && (intTemp == 4 || intTemp == 5);
        heater = intTemp != 5;
        temp = intTemp;
        //intTemp = temp; TODO: check if this is allowed in the future

        for (var i: INT = 0 to 5 by 1) {
            lightLevel = i * 20;
            
            if (i == 5) {
                lights = false;
            } else {
                lights = true;
            }
            
            lights = i != 5;
        }

        var dimmedLightVal: INT = 0;
        var isLightOn: BOOL = false;
        use LightLogicFB(iLightLevel: 60) -> { oLight: isLightOn, oDimmedLight: dimmedLightVal };
        use HeatingLogicFB(iTemp: 25.0, iWindow: false, iMode: Mode.ECO) -> heater;
        use HeatingLogicFB(iTemp: 25.0, iWindow: false, iMode: Mode.ECO) -> { oHeating: heater };
    }
}
